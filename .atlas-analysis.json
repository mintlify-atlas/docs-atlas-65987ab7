  "keyFeatures": [
    "WAF protection with Coraza and OWASP Core Rule Set",
    "Reverse proxy with multi-backend routing and load balancing",
    "Per-IP rate limiting with automatic cleanup",
    "GeoIP-based access control (allow/block countries)",
    "Bot detection and blocking",
    "Separate protection profiles for APIs (PL2) and websites (PL1)",
    "Docker and Docker Compose deployment",
    "Comprehensive request/response inspection",
    "Audit logging for security events"
  ],
